{
  "ConnectionStrings": {
    "Default": "Data Source=opsmonitor.db"
  },
  "Jwt": {
    "Issuer": "OpsMonitor",
    "Audience": "OpsMonitor",
    "SigningKey": "CHANGE_THIS_TO_A_STRONG_32BYTE_KEY",
    "ExpiresMinutes": 480
  },
  "Security": {
    "ConfigEncryptionKey": "CHANGE_THIS_TO_A_STRONG_32BYTE_KEY"
  },
  "Seed": {
    "AdminUserName": "admin",
    "AdminPassword": "ChangeMe123!"
  },
  "Monitoring": {
    "ResultRetentionDays": 30,
    "SchedulerTickMs": 1000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
